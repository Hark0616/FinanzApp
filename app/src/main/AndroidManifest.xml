<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permiso para acceder a notificaciones de otras apps -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Internet para fallback de IA (OpenRouter) y backup opcional -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Evitar que el sistema mate el servicio de notificaciones -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".FinanzApplication"
        android:allowBackup="${appAllowBackup}"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinanzApp">

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FinanzApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Manejo de deep links para App Shortcuts y Widgets -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="finanzapp" android:host="transactions" />
            </intent-filter>

            <!-- Declaración de shortcuts estáticos -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Dialog flotante premium para registro rápido -->
        <activity
            android:name=".ui.quickadd.QuickAddActivity"
            android:exported="true"
            android:theme="@style/Theme.QuickAdd">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="finanzapp" android:host="quickadd" />
            </intent-filter>
        </activity>

        <!-- Servicio de Quick Settings Tile -->
        <service
            android:name=".ui.quickadd.QuickAddTileService"
            android:exported="true"
            android:label="Registrar Gasto"
            android:icon="@drawable/ic_shortcut_add"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>



        <!-- Servicio que escucha las notificaciones del sistema -->
        <service
            android:name=".data.notification.TransactionNotificationListenerService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Receiver para reiniciar el listener tras reinicio del dispositivo -->
        <receiver
            android:name=".data.notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Receiver para simular notificaciones bancarias en pruebas locales -->
        <receiver
            android:name=".data.notification.NotificationSimulatorReceiver"
            android:exported="${debugToolsExported}"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="com.ivan.finanzapp.SIMULATE_NOTIFICATION" />
            </intent-filter>
        </receiver>

        <!-- Receiver para el Widget de Glance -->
        <receiver
            android:name=".ui.widget.FinanzAppWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/app_widget_info" />
        </receiver>

        <!-- Receiver para el Widget de Autonomía -->
        <receiver
            android:name=".ui.widget.AutonomiaWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_autonomia_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/autonomia_widget_info" />
        </receiver>

        <!-- Receiver para el Widget de Próximo Vencimiento -->
        <receiver
            android:name=".ui.widget.ProximoVencimientoWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_vencimiento_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/proximo_vencimiento_widget_info" />
        </receiver>

        <!-- Receiver para el Widget de Disponible Neto -->
        <receiver
            android:name=".ui.widget.DisponibleNetoWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_disponible_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/disponible_neto_widget_info" />
        </receiver>

    </application>

</manifest>
