<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="add_transaction"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_add_adaptive"
        android:shortcutShortLabel="@string/shortcut_add_label"
        android:shortcutLongLabel="@string/shortcut_add_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.ivan.finanzapp"
            android:targetClass="com.ivan.finanzapp.MainActivity"
            android:data="finanzapp://transactions?action=add_expense" />
    </shortcut>
    <shortcut
        android:shortcutId="view_unclassified"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_unclassified_adaptive"
        android:shortcutShortLabel="@string/shortcut_unclassified_label"
        android:shortcutLongLabel="@string/shortcut_unclassified_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.ivan.finanzapp"
            android:targetClass="com.ivan.finanzapp.MainActivity"
            android:data="finanzapp://transactions?action=view_unclassified" />
    </shortcut>

    <!-- Capacidad de App Actions para registro por voz con Google Assistant / Gemini -->
    <capability android:name="custom.actions.intent.CREATE_EXPENSE">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.ivan.finanzapp"
            android:targetClass="com.ivan.finanzapp.ui.quickadd.QuickAddActivity">
            <url-template android:value="finanzapp://quickadd?amount={amount}&amp;merchant={merchant}&amp;voice=true" />
            <parameter
                android:name="amount"
                android:key="amount" />
            <parameter
                android:name="merchant"
                android:key="merchant" />
        </intent>
    </capability>
</shortcuts>
